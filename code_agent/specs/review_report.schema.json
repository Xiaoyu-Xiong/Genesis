{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "review_report.schema.json",
  "title": "Review Report",
  "type": "object",
  "required": ["verdict", "findings", "scope_violations", "recommended_next_step"],
  "properties": {
    "verdict": { "type": "string", "enum": ["pass", "needs_repair", "blocked"] },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "owner", "summary"],
        "properties": {
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "owner": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "file": { "type": ["string", "null"] },
          "line": { "type": ["integer", "null"], "minimum": 1 },
          "recommendation": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "scope_violations": { "type": "array", "items": { "type": "string" } },
    "recommended_next_step": {
      "type": "string",
      "enum": ["execute", "repair", "replan", "stop"]
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "unresolved_risks": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
