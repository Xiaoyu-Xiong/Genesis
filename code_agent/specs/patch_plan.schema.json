{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "patch_plan.schema.json",
  "title": "Patch Plan",
  "type": "object",
  "required": ["target_owner", "problem_summary", "patches", "validation_plan"],
  "properties": {
    "target_owner": {
      "type": "string",
      "enum": ["planner", "scene", "body", "action", "integrator", "execution", "asset", "multiple"]
    },
    "problem_summary": { "type": "string", "minLength": 1 },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "patches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["owner", "allowed_paths", "instructions"],
        "properties": {
          "owner": { "type": "string", "minLength": 1 },
          "allowed_paths": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "instructions": { "type": "string", "minLength": 1 },
          "forbidden_paths": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "validation_plan": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "risks": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
