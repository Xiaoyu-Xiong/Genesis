{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "planner_action.schema.json",
  "title": "Planner Action",
  "type": "object",
  "required": [
    "action",
    "rationale",
    "planner_output",
    "asset_names",
    "roles",
    "owner",
    "repair_brief",
    "backend",
    "render",
    "timeout_sec",
    "cwd",
    "python_args",
    "pytest_args",
    "verdict",
    "summary",
    "notes"
  ],
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "write_plan",
        "start_mesh_assets",
        "wait_mesh_assets",
        "update_mesh_asset_metadata",
        "start_xml_assets",
        "wait_xml_assets",
        "inspect_assets",
        "spawn_workers",
        "run_integrator",
        "run_execution",
        "run_critic",
        "run_opt",
        "request_repair",
        "run_python",
        "run_pytest",
        "finish"
      ]
    },
    "rationale": { "type": "string", "minLength": 1 },
    "planner_output": {
      "type": ["object", "null"],
      "required": [
        "scene_brief",
        "scene_plan",
        "asset_requests",
        "module_contracts",
        "dispatch_graph",
        "execution_plan",
        "risk_register"
      ],
      "properties": {
        "scene_brief": {
          "type": "object",
          "required": [
            "user_intent",
            "required_entities",
            "interaction_goal",
            "success_criteria",
            "failure_criteria",
            "assumptions"
          ],
          "properties": {
            "user_intent": { "type": "string", "minLength": 1 },
            "required_entities": { "type": "array", "items": { "type": "string" } },
            "interaction_goal": { "type": "string", "minLength": 1 },
            "success_criteria": { "type": "array", "items": { "type": "string" } },
            "failure_criteria": { "type": "array", "items": { "type": "string" } },
            "assumptions": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "scene_plan": {
          "type": "object",
          "required": ["simulation_strategy", "physics_risks", "resource_level", "rendering_needs"],
          "properties": {
            "simulation_strategy": { "type": "string", "minLength": 1 },
            "physics_risks": { "type": "array", "items": { "type": "string" } },
            "resource_level": { "type": "string", "enum": ["low", "medium", "high"] },
            "rendering_needs": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "asset_requests": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "asset_type",
              "purpose",
              "scale",
              "bbox",
              "texture_needs",
              "simulation_role"
            ],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "asset_type": { "type": "string", "minLength": 1 },
              "purpose": { "type": "string", "minLength": 1 },
              "scale": { "type": ["number", "null"], "exclusiveMinimum": 0 },
              "bbox": { "type": ["array", "null"], "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
              "texture_needs": { "type": ["string", "null"] },
              "simulation_role": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "module_contracts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "owner_role",
              "target_files",
              "allowed_write_paths",
              "required_exports",
              "input_dependencies",
              "asset_dependencies",
              "forbidden_edits",
              "validation_expectation",
              "final_report_schema"
            ],
            "properties": {
              "owner_role": { "type": "string", "minLength": 1 },
              "target_files": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
              "allowed_write_paths": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
              "required_exports": { "type": "array", "items": { "type": "string" } },
              "input_dependencies": { "type": "array", "items": { "type": "string" } },
              "asset_dependencies": { "type": "array", "items": { "type": "string" } },
              "forbidden_edits": { "type": "array", "items": { "type": "string" } },
              "validation_expectation": { "type": ["string", "null"] },
              "final_report_schema": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "dispatch_graph": {
          "type": "object",
          "required": ["nodes", "edges", "parallel_groups", "wait_for_asset_manifest"],
          "properties": {
            "nodes": { "type": "array", "items": { "type": "string" } },
            "edges": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["from", "to", "reason"],
                "properties": {
                  "from": { "type": "string" },
                  "to": { "type": "string" },
                  "reason": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            "parallel_groups": { "type": "array", "items": { "type": "array", "items": { "type": "string" } } },
            "wait_for_asset_manifest": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "execution_plan": {
          "type": "object",
          "required": ["mode", "backend", "duration_sec", "step_budget", "render_fps", "render_budget", "notes"],
          "properties": {
            "mode": { "type": "string", "enum": ["local_gpu", "local_cpu", "skip"] },
            "backend": { "type": ["string", "null"], "enum": ["gpu", "cpu", null] },
            "duration_sec": { "type": "number", "exclusiveMinimum": 0 },
            "step_budget": { "type": "integer", "minimum": 0 },
            "render_fps": { "type": "integer", "minimum": 1 },
            "render_budget": { "type": "integer", "minimum": 0 },
            "notes": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "risk_register": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "asset_names": { "type": ["array", "null"], "items": { "type": "string" } },
    "roles": {
      "type": ["array", "null"],
      "items": { "type": "string", "enum": ["scene", "body", "action", "rendering"] }
    },
    "owner": {
      "type": ["string", "null"],
      "enum": ["scene", "body", "action", "rendering", "planner", "integrator", "execution", "none", null]
    },
    "repair_brief": { "type": ["string", "null"] },
    "backend": { "type": ["string", "null"], "enum": ["gpu", "cpu", null] },
    "render": { "type": ["boolean", "null"] },
    "timeout_sec": { "type": ["number", "null"], "exclusiveMinimum": 0 },
    "cwd": { "type": ["string", "null"], "enum": ["repo", "case", null] },
    "python_args": { "type": ["array", "null"], "items": { "type": "string" } },
    "pytest_args": { "type": ["array", "null"], "items": { "type": "string" } },
    "verdict": { "type": ["string", "null"], "enum": ["pass", "fail", "inconclusive", null] },
    "summary": { "type": ["string", "null"] },
    "notes": { "type": ["array", "null"], "items": { "type": "string" } }
  },
  "additionalProperties": false
}
