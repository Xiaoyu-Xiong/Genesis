{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "planner_action.schema.json",
  "title": "Planner Action",
  "type": "object",
  "required": [
    "action",
    "rationale",
    "planner_output",
    "asset_names",
    "roles",
    "owner",
    "repair_brief",
    "backend",
    "render",
    "render_profile",
    "save_state_cache",
    "require_state_cache",
    "replay_cache",
    "render_only",
    "timeout_sec",
    "cwd",
    "python_args",
    "pytest_args",
    "verdict",
    "summary",
    "notes",
    "simdebug_cards"
  ],
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "write_plan",
        "start_mesh_assets",
        "wait_mesh_assets",
        "update_mesh_asset_metadata",
        "start_xml_assets",
        "wait_xml_assets",
        "inspect_assets",
        "spawn_workers",
        "run_integrator",
        "run_execution",
        "run_critic",
        "run_opt",
        "request_repair",
        "run_python",
        "run_pytest",
        "finish"
      ]
    },
    "rationale": { "type": "string", "minLength": 1 },
    "planner_output": {
      "type": ["object", "null"],
      "required": [
        "scene_brief",
        "physics_plan",
        "scene_plan",
        "asset_requests",
        "module_contracts",
        "dispatch_graph",
        "execution_plan",
        "risk_register"
      ],
      "properties": {
        "scene_brief": {
          "type": "object",
          "required": [
            "user_intent",
            "required_entities",
            "interaction_goal",
            "success_criteria",
            "failure_criteria",
            "assumptions"
          ],
          "properties": {
            "user_intent": { "type": "string", "minLength": 1 },
            "required_entities": { "type": "array", "items": { "type": "string" } },
            "interaction_goal": { "type": "string", "minLength": 1 },
            "success_criteria": { "type": "array", "items": { "type": "string" } },
            "failure_criteria": { "type": "array", "items": { "type": "string" } },
            "assumptions": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "physics_plan": {
          "type": "object",
          "required": ["mode", "deformable_enabled", "deformable_kind", "ipc_enabled", "rationale"],
          "properties": {
            "mode": { "type": "string", "enum": ["rigid", "rigid_ipc", "fem_ipc"] },
            "deformable_enabled": { "type": "boolean" },
            "deformable_kind": { "type": "string", "enum": ["none", "soft_body", "cloth", "soft_body_and_cloth"] },
            "ipc_enabled": { "type": "boolean" },
            "rationale": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "scene_plan": {
          "type": "object",
          "required": ["simulation_strategy", "physics_risks", "resource_level", "rendering_needs"],
          "properties": {
            "simulation_strategy": { "type": "string", "minLength": 1 },
            "physics_risks": { "type": "array", "items": { "type": "string" } },
            "resource_level": { "type": "string", "enum": ["low", "medium", "high"] },
            "rendering_needs": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "asset_requests": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "asset_type",
              "purpose",
              "scale",
              "bbox",
              "cloth_target_edge_length",
              "texture_needs",
              "simulation_role"
            ],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "asset_type": { "type": "string", "minLength": 1 },
              "purpose": { "type": "string", "minLength": 1 },
              "scale": { "type": ["number", "null"], "exclusiveMinimum": 0 },
              "bbox": { "type": ["array", "null"], "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
              "cloth_target_edge_length": { "type": ["number", "null"], "exclusiveMinimum": 0 },
              "texture_needs": { "type": ["string", "null"] },
              "simulation_role": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "module_contracts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "owner_role",
              "target_files",
              "allowed_write_paths",
              "required_exports",
              "input_dependencies",
              "asset_dependencies",
              "forbidden_edits",
              "validation_expectation",
              "final_report_schema"
            ],
            "properties": {
              "owner_role": { "type": "string", "minLength": 1 },
              "target_files": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
              "allowed_write_paths": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
              "required_exports": { "type": "array", "items": { "type": "string" } },
              "input_dependencies": { "type": "array", "items": { "type": "string" } },
              "asset_dependencies": { "type": "array", "items": { "type": "string" } },
              "forbidden_edits": { "type": "array", "items": { "type": "string" } },
              "validation_expectation": { "type": ["string", "null"] },
              "final_report_schema": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "dispatch_graph": {
          "type": "object",
          "required": ["nodes", "edges", "parallel_groups", "wait_for_asset_manifest"],
          "properties": {
            "nodes": { "type": "array", "items": { "type": "string" } },
            "edges": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["from", "to", "reason"],
                "properties": {
                  "from": { "type": "string" },
                  "to": { "type": "string" },
                  "reason": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            "parallel_groups": { "type": "array", "items": { "type": "array", "items": { "type": "string" } } },
            "wait_for_asset_manifest": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "execution_plan": {
          "type": "object",
          "required": [
            "mode",
            "backend",
            "duration_sec",
            "step_budget",
            "sim_dt",
            "sim_substeps",
            "render_every_n_steps",
            "render_fps",
            "render_budget",
            "render_res",
            "notes"
          ],
          "properties": {
            "mode": { "type": "string", "enum": ["local_gpu", "local_cpu", "skip"] },
            "backend": { "type": ["string", "null"], "enum": ["gpu", "cpu", null] },
            "duration_sec": { "type": "number", "exclusiveMinimum": 0 },
            "step_budget": { "type": "integer", "minimum": 0 },
            "sim_dt": { "type": "number", "exclusiveMinimum": 0 },
            "sim_substeps": { "type": "integer", "minimum": 1 },
            "render_every_n_steps": { "type": "integer", "minimum": 1 },
            "render_fps": { "type": "integer", "minimum": 1 },
            "render_budget": { "type": "integer", "minimum": 0 },
            "render_res": {
              "type": "array",
              "items": { "type": "integer", "minimum": 1 },
              "minItems": 2,
              "maxItems": 2
            },
            "notes": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "risk_register": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "asset_names": { "type": ["array", "null"], "items": { "type": "string" } },
    "roles": {
      "type": ["array", "null"],
      "items": { "type": "string", "enum": ["scene", "body", "action", "rendering"] }
    },
    "owner": {
      "type": ["string", "null"],
      "enum": ["scene", "body", "action", "rendering", "planner", "integrator", "execution", "none", null]
    },
    "repair_brief": { "type": ["string", "null"] },
    "backend": { "type": ["string", "null"], "enum": ["gpu", "cpu", null] },
    "render": { "type": ["boolean", "null"] },
    "render_profile": {
      "type": ["string", "null"],
      "enum": ["debug_raster", "final_path_traced", null],
      "description": "Execution render mode. Use debug_raster for physics evidence; use final_path_traced for the mandatory final GPU RayTracer look-dev pass."
    },
    "save_state_cache": {
      "type": ["boolean", "null"],
      "description": "Normal physics executions always write artifacts/state_cache manifest and frame npz files. This field is kept for explicit planner intent but false is ignored outside render-only replay."
    },
    "require_state_cache": {
      "type": ["boolean", "null"],
      "description": "Normal physics executions always fail if the state cache manifest or referenced npz files are missing. This field is kept for explicit planner intent but false is ignored outside render-only replay."
    },
    "replay_cache": {
      "type": ["string", "null"],
      "description": "Path to an accepted state_cache/manifest.json for render-only replay."
    },
    "render_only": {
      "type": ["boolean", "null"],
      "description": "When true, render from replay_cache without stepping physics."
    },
    "timeout_sec": { "type": ["number", "null"], "exclusiveMinimum": 0 },
    "cwd": { "type": ["string", "null"], "enum": ["repo", "case", null] },
    "python_args": { "type": ["array", "null"], "items": { "type": "string" } },
    "pytest_args": { "type": ["array", "null"], "items": { "type": "string" } },
    "verdict": { "type": ["string", "null"], "enum": ["pass", "fail", "inconclusive", null] },
    "summary": { "type": ["string", "null"] },
    "notes": { "type": ["array", "null"], "items": { "type": "string" } },
    "simdebug_cards": {
      "type": ["object", "null"],
      "description": "Optional Planner-selected SimDebug card ids to dispatch with this action. Use role buckets for downstream agents; omit by using null when default role/physics candidates are sufficient.",
      "required": [
        "all",
        "workers",
        "all_workers",
        "planner",
        "scene",
        "body",
        "action",
        "rendering",
        "critic",
        "opt"
      ],
      "properties": {
        "all": { "type": ["array", "null"], "items": { "type": "string" } },
        "workers": { "type": ["array", "null"], "items": { "type": "string" } },
        "all_workers": { "type": ["array", "null"], "items": { "type": "string" } },
        "planner": { "type": ["array", "null"], "items": { "type": "string" } },
        "scene": { "type": ["array", "null"], "items": { "type": "string" } },
        "body": { "type": ["array", "null"], "items": { "type": "string" } },
        "action": { "type": ["array", "null"], "items": { "type": "string" } },
        "rendering": { "type": ["array", "null"], "items": { "type": "string" } },
        "critic": { "type": ["array", "null"], "items": { "type": "string" } },
        "opt": { "type": ["array", "null"], "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
