{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "asset_manifest.schema.json",
  "title": "Asset Manifest",
  "type": "object",
  "required": ["assets"],
  "properties": {
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["logical_name", "source_type", "runtime_path", "simulation_role"],
        "properties": {
          "logical_name": { "type": "string", "minLength": 1 },
          "source_type": {
            "type": "string",
            "enum": ["primitive", "generated_mesh", "repo_asset", "mjcf", "urdf"]
          },
          "runtime_path": { "type": "string", "minLength": 1 },
          "visual_path": { "type": ["string", "null"] },
          "scale": { "type": ["array", "null"], "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
          "bbox": { "type": ["array", "null"], "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
          "file_meshes_are_zup": { "type": ["boolean", "null"] },
          "texture_path": { "type": ["string", "null"] },
          "texture_paths": {
            "type": "object",
            "additionalProperties": { "type": "string", "minLength": 1 }
          },
          "joints": { "type": "array", "items": { "type": "object" } },
          "actuators": { "type": "array", "items": { "type": "object" } },
          "control_interface": { "type": "object" },
          "base": { "type": "object" },
          "validation": { "type": "object" },
          "simulation_role": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["ready", "pending", "failed"] },
          "notes": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "unresolved_risks": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
