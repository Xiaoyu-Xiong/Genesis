  "genesis_adaptation_guidelines": {
    "preserve_exactly": [
      "separate rigid bodies for every link",
      "90-degree alternating neighboring link orientations",
      "contact-only chain-to-anchor load transfer",
      "fixed-position axle/spool rotating around its local X axis",
      "brief gravity-driven release before sustained winding",
      "no ground plane when the case prompt asks for white-background no-ground rendering"
    ],
    "allowed_adaptations": [
      "scale the source fixture down uniformly to fit the Genesis camera and IPC stability budget",
      "replace the source axle mesh with a simple collision-enabled horizontal cylinder plus flanges if the source spool mesh is unavailable",
      "add a collision guide eye only if the prompt requests it, but do not treat it as part of the original source fixture",
      "extend the chain beyond 21 links only by continuing the same pitch and 90-degree alternation pattern, and document that extension as a Genesis adaptation"
    ],
    "forbidden_adaptations": [
      "fusing the chain into one mesh",
      "using a rope, tube, curve, cable, tendon, weld, or hidden joint for the chain",
      "teleporting or directly driving passive links or the anchor after initialization",
      "turning off rigid-rigid collision for the link, spool, or anchor load path"
    ]
  }
